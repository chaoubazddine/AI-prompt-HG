// Prisma Schema for Jadha Social AI
// This is a conceptual schema as requested.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(TEACHER)
  jadhas        Jadha[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  TEACHER
  ADMIN
}

model Jadha {
  id           String   @id @default(cuid())
  title        String
  level        String
  year         String
  duration     String
  unit         String
  curriculum   String?
  
  // JSON fields for complex data
  competencies Json     // String[]
  capabilities Json     // String[]
  objectives   Json     // { cognitive: string[], skill: string[], affective: string[] }
  steps        Json     // JadhaStep[]
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

